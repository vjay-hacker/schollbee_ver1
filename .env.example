# ================================================================
# SchoolBee — Environment Variables Example
# Copy to .env.development / .env.staging / .env.production
# NEVER commit real values to git
# ================================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug                  # debug | info | warn | error
API_VERSION=v1

# ── Supabase (get from https://supabase.com/dashboard) ───────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-keep-secret

# ── JWT ────────────────────────────────────────────────────────
# MUST be at least 32 characters, generated randomly
# Generate: openssl rand -base64 48
JWT_SECRET=your-very-long-random-jwt-secret-here

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=                  # Leave empty for dev, set for prod

# ── OpenAI (AI Assistant) ──────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini         # gpt-4o | gpt-4o-mini | gpt-3.5-turbo

# ── Google Maps (Bus Tracking) ─────────────────────────────────
# Get from https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=AIzaSy-your-maps-api-key
GOOGLE_MAPS_GEOCODING_ENABLED=true

# ── Firebase Cloud Messaging (Push Notifications) ─────────────
# Get from Firebase Console > Project Settings > Service Accounts
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-key-here\n-----END RSA PRIVATE KEY-----"

# ── Email / SMTP ───────────────────────────────────────────────
# SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey
# Mailhog (dev): SMTP_HOST=localhost, SMTP_PORT=1025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=SchoolBee
SMTP_FROM_EMAIL=noreply@schoolbee.app

# ── WhatsApp Business API ──────────────────────────────────────
# Twilio / 360dialog / WhatsApp Cloud API
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# ── Twilio SMS ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15551234567

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_MAX_REQUESTS=500     # general
AUTH_RATE_LIMIT_MAX=100         # auth endpoints

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8081,http://localhost:3000,https://schoolbee.app

# ── Backup (production only) ───────────────────────────────────
BACKUP_S3_BUCKET=schoolbee-backups
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=          # openssl rand -base64 32

# ── Monitoring ──────────────────────────────────────────────────
METRICS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
DOMAIN=schoolbee.app

# ── Supabase DB (for direct psql/pg_dump access) ──────────────
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-db-password
SUPABASE_ACCESS_TOKEN=sbp_your-supabase-access-token
